<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Views.MapPage"
             xmlns:helpers="clr-namespace:VinhKhanhTour.Helpers"
             xmlns:services="clr-namespace:VinhKhanhTour.Services"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:TranslateConverter x:Key="Translate" />
    </ContentPage.Resources>

    <Grid x:Name="RootGrid" RowDefinitions="*, 80">

        <Grid x:Name="MapContainer" Grid.Row="0">

            <WebView x:Name="BanDoWebView" HorizontalOptions="Fill" VerticalOptions="Fill" Navigating="BanDoWebView_Navigating" />

            <Grid InputTransparent="True">

                <Border Margin="{OnIdiom Phone='15,45,15,0', Tablet='30,60,30,0'}"
                        Padding="15,10" HorizontalOptions="Center" VerticalOptions="Start"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                        StrokeShape="RoundRectangle 24" StrokeThickness="0">
                    <HorizontalStackLayout Spacing="10">
                        <Border StrokeShape="RoundRectangle 5" WidthRequest="10" HeightRequest="10" BackgroundColor="#27AE60" StrokeThickness="0" VerticalOptions="Center" />
                        <Label x:Name="DebugLabel" Text="Radar đang quét..." FontSize="{OnIdiom Phone=13, Tablet=15}" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Border x:Name="BottomInfoCard" VerticalOptions="End" Margin="{OnIdiom Phone='12,0,12,24', Tablet='40,0,40,40'}" Padding="0"
                        StrokeShape="RoundRectangle 20" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" StrokeThickness="0"
                        HorizontalOptions="{OnIdiom Phone=Fill, Tablet=Center}" InputTransparent="False">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BottomInfoCard_Tapped" />
                    </Border.GestureRecognizers>

                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" Padding="{OnIdiom Phone='20,16', Tablet='24,20'}">

                        <VerticalStackLayout Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                            <Label x:Name="CardStatusLabel" Text="BẠN ĐANG Ở GẦN" FontSize="10" FontAttributes="Bold" TextColor="#FF5C0F" CharacterSpacing="1" />
                            <Label x:Name="PoiNameLabel" Text="Đang dò tìm..." FontSize="{OnIdiom Phone=18, Tablet=22}" FontAttributes="Bold" MaxLines="2" LineBreakMode="WordWrap"/>
                            <Label x:Name="DistanceLabel" Text="Khoảng cách: -- m" FontSize="{OnIdiom Phone=13, Tablet=15}" Opacity="0.6"/>
                            <Label Text="👆 Chạm để xem chi tiết" FontSize="11" TextColor="#27AE60" Margin="0,4,0,0"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Row="{OnIdiom Phone=1, Tablet=0}" Grid.Column="{OnIdiom Phone=0, Tablet=1}" Grid.ColumnSpan="{OnIdiom Phone=2, Tablet=1}"
                                               HorizontalOptions="Center" VerticalOptions="Center" Spacing="16" Margin="{OnIdiom Phone='0,14,0,0', Tablet='0,0,0,0'}">
                            <Button Text="📍" x:Name="RouteButton" FontSize="24" BackgroundColor="#FFF0ED" TextColor="#FF5C0F" WidthRequest="56" HeightRequest="56" CornerRadius="28" Padding="0" Clicked="OnRouteClicked" />
                            <Button Text="⏸" x:Name="PlayPauseButton" FontSize="28" BackgroundColor="#FF5C0F" TextColor="White" WidthRequest="56" HeightRequest="56" CornerRadius="28" Padding="0" Clicked="OnPlayPauseClicked" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>