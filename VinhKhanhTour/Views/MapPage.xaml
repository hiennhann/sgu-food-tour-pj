<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Views.MapPage"
             xmlns:helpers="clr-namespace:VinhKhanhTour.Helpers"
             xmlns:services="clr-namespace:VinhKhanhTour.Services"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:TranslateConverter x:Key="Translate" />
    </ContentPage.Resources>

    <Grid x:Name="RootGrid" RowDefinitions="*, 80">

        <Grid x:Name="MapContainer" Grid.Row="0">

            <WebView x:Name="BanDoWebView" HorizontalOptions="Fill" VerticalOptions="Fill" Navigating="BanDoWebView_Navigating" />

            <Grid InputTransparent="True">

                <Border Margin="{OnIdiom Phone='15,45,15,0', Tablet='30,60,30,0'}"
                        Padding="15,10" HorizontalOptions="Center" VerticalOptions="Start"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                        StrokeShape="RoundRectangle 24" StrokeThickness="0">
                    <HorizontalStackLayout Spacing="10">
                        <Border StrokeShape="RoundRectangle 5" WidthRequest="10" HeightRequest="10" BackgroundColor="#27AE60" StrokeThickness="0" VerticalOptions="Center" />
                        <Label x:Name="DebugLabel" Text="Radar đang quét..." FontSize="{OnIdiom Phone=13, Tablet=15}" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Border x:Name="BottomInfoCard" VerticalOptions="End" Margin="16,0,16,24" Padding="0"
                        StrokeShape="RoundRectangle 20" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" StrokeThickness="0"
                        HorizontalOptions="Fill" InputTransparent="False">

                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.15" />
                    </Border.Shadow>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BottomInfoCard_Tapped" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="*, Auto" Padding="20,16" ColumnSpacing="12" VerticalOptions="Center">

                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="CardStatusLabel" Text="BẠN ĐANG Ở GẦN" FontSize="10" FontAttributes="Bold" TextColor="#FF5C0F" CharacterSpacing="1" />

                            <Label x:Name="PoiNameLabel" Text="Đang dò tìm..." FontSize="20" FontAttributes="Bold" MaxLines="1" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,2,0,2"/>

                            <Label x:Name="DistanceLabel" Text="Khoảng cách: -- m" FontSize="13" TextColor="#808080" MaxLines="1" LineBreakMode="TailTruncation"/>

                            <HorizontalStackLayout Spacing="4" Margin="0,4,0,0">
                                <Label Text="👆" FontSize="11" VerticalOptions="Center"/>
                                <Label Text="Chạm để xem chi tiết" FontSize="11" TextColor="#27AE60" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="10">
                            <Button Text="📍" x:Name="RouteButton" FontSize="20" BackgroundColor="#FFF0ED" TextColor="#FF5C0F" 
                                    WidthRequest="48" HeightRequest="48" CornerRadius="24" Padding="0" Clicked="OnRouteClicked" />
                            <Button Text="⏸" x:Name="PlayPauseButton" FontSize="20" BackgroundColor="#FF5C0F" TextColor="White" 
                                    WidthRequest="48" HeightRequest="48" CornerRadius="24" Padding="0" Clicked="OnPlayPauseClicked" />
                        </HorizontalStackLayout>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>