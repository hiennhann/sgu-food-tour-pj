<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Views.PaywallPage"
             Title="Paywall"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

            <Label x:Name="TitleLabel" Text="HẾT HẠN DÙNG THỬ!"
                   FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="Red"/>

            <Label Text="Vui lòng thanh toán phí ứng dụng một lần duy nhất để tiếp tục sử dụng tính năng."
                   FontSize="16" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="Black"/>

            <Frame BackgroundColor="#F9F9F9" Padding="20" CornerRadius="15" HasShadow="True">
                <VerticalStackLayout Spacing="15">

                    <Label Text="Quét mã QR để Thanh toán" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black"/>

                    <!-- Thuộc tính x:Name để code-behind gọi lệnh -->
                    <Image x:Name="QRCodeImage"
                           HeightRequest="250"
                           WidthRequest="250"
                           HorizontalOptions="Center"/>

                    <Label Text="Số tiền: 199.000 VNĐ" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#4CAF50"/>

                    <!-- Thuộc tính x:Name để code-behind gán ID tự động -->
                    <Label x:Name="TransferContentLabel"
                           Text="Nội dung ck: ..."
                           FontSize="14" HorizontalOptions="Center" TextColor="Gray" FontAttributes="Italic"/>

                </VerticalStackLayout>
            </Frame>

            <Label Text="Sau khi chuyển khoản thành công, vui lòng chờ Admin kích hoạt hoặc bấm nút bên dưới để kiểm tra lại."
                   FontSize="13" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="#666666"/>

            <Button Text="Kiểm tra trạng thái Thanh Toán"
                    Clicked="OnCheckPaymentClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontAttributes="Bold"
                    Margin="0, 10, 0, 0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>