@model VinhKhanhTour.CMS.Models.Tour
@{
    ViewData["Title"] = "Add Tour";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-light text-muted me-3 shadow-sm" style="border-radius: 8px;"><i class="bi bi-arrow-left"></i> Back</a>
    <h3 class="fw-bold text-dark mb-0">Add New Tour</h3>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="TourName" class="form-label text-muted fw-bold">Tên Tour</label>
                    <input asp-for="TourName" class="form-control bg-light border-0" placeholder="vd: Tour Ăn Vặt 100k" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PoiIds" class="form-label text-muted fw-bold">ID các quán (cách nhau dấu phẩy)</label>
                    <input asp-for="PoiIds" class="form-control bg-light border-0" placeholder="vd: 1,3,5" />
                </div>
                <div class="col-12 mb-3">
                    <label asp-for="Description" class="form-label text-muted fw-bold">Mô tả Tour</label>
                    <textarea asp-for="Description" class="form-control bg-light border-0" rows="3"></textarea>
                </div>
                <div class="col-12 mb-4">
                    <label asp-for="CoverImageUrl" class="form-label text-muted fw-bold">Tên File Hình Ảnh Cover</label>
                    <input asp-for="CoverImageUrl" class="form-control bg-light border-0" />
                </div>
            </div>
            <hr class="text-muted my-4" />
            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm" style="border-radius: 8px;"><i class="bi bi-save me-1"></i> Save Data</button>
            </div>
        </form>
    </div>
</div>