@model VinhKhanhTour.CMS.Models.Tour
@{
    ViewData["Title"] = "Add Tour";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-light text-muted me-3 shadow-sm" style="border-radius: 8px;"><i class="bi bi-arrow-left"></i> Back</a>
    <h3 class="fw-bold text-dark mb-0">Add New Tour</h3>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="TourName" class="form-label text-muted fw-bold">Tên Tour</label>
                    <input asp-for="TourName" class="form-control bg-light border-0" placeholder="vd: Tour Ăn Vặt 100k" required />
                </div>
                <div class="col-12 mb-3">
                    <label class="form-label text-muted fw-bold">Chọn các quán ăn trong Tour này:</label>
                    <div class="bg-light p-3 rounded" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var poi in (List<VinhKhanhTour.CMS.Models.Poi>)ViewBag.PoiList)
                        {
                            <div class="form-check">
                                <input class="form-check-input poi-checkbox" type="checkbox" value="@poi.Id" id="poi_@poi.Id">
                                <label class="form-check-label" for="poi_@poi.Id">
                                    <strong>#@poi.Id</strong> - @poi.Name
                                </label>
                            </div>
                        }
                    </div>
                    <input type="hidden" asp-for="PoiIds" id="FinalPoiIds" />
                </div>

                <script>
                                    // Script để tự động nối các ID khi Admin click chọn
                                    document.querySelectorAll('.poi-checkbox').forEach(cb => {
                                        cb.addEventListener('change', () => {
                                            let selectedIds = Array.from(document.querySelectorAll('.poi-checkbox:checked'))
                                                                   .map(c => c.value)
                                                                   .join(',');
                                            document.getElementById('FinalPoiIds').value = selectedIds;
                                        });
                                    });
                </script>
                <div class="col-12 mb-3">
                    <label asp-for="Description" class="form-label text-muted fw-bold">Mô tả Tour</label>
                    <textarea asp-for="Description" class="form-control bg-light border-0" rows="3" required></textarea>
                </div>
                <div class="col-12 mb-4">
                    <label class="form-label text-muted fw-bold">Hình Ảnh Cover</label>
                    <input type="file" name="ImageFile" class="form-control bg-light border-0" accept="image/*" />
                </div>
            </div>
            <hr class="text-muted my-4" />
            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm" style="border-radius: 8px;">
                    <i class="bi bi-save me-1"></i> Save Data
                </button>
            </div>
        </form>
    </div>
</div>