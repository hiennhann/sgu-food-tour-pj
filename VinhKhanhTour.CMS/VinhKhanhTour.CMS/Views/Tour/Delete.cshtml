@model VinhKhanhTour.CMS.Models.Tour
@{
    ViewData["Title"] = "Delete Tour";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card border-danger shadow" style="border-radius: 10px;">
            <div class="card-header bg-danger text-white fw-bold text-center py-3" style="border-radius: 10px 10px 0 0;">
                <i class="bi bi-exclamation-triangle-fill fs-4 d-block mb-1"></i> XÓA TOUR NÀY?
            </div>
            <div class="card-body p-4 text-center">
                <h5 class="fw-bold">@Model.TourName</h5>
                <p class="text-muted small">@Model.Description</p>
                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-light fw-bold px-4 me-2" style="border-radius: 8px;">Hủy</a>
                    <button type="submit" class="btn btn-danger fw-bold px-4 shadow-sm" style="border-radius: 8px;">Xóa Vĩnh Viễn</button>
                </form>
            </div>
        </div>
    </div>
</div>