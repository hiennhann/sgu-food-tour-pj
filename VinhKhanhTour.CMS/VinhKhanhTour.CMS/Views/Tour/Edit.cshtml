@model VinhKhanhTour.CMS.Models.Tour
@{
    ViewData["Title"] = "Edit Tour";
}
<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-light text-muted me-3 shadow-sm" style="border-radius: 8px;"><i class="bi bi-arrow-left"></i> Back</a>
    <h3 class="fw-bold text-dark mb-0">Cập Nhật Tour</h3>
</div>
<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CoverImageUrl" />
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="TourName" class="form-label text-muted fw-bold">Tên Tour</label>
                    <input asp-for="TourName" class="form-control bg-light border-0" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PoiIds" class="form-label text-muted fw-bold">ID các quán (cách nhau dấu phẩy)</label>
                    <input asp-for="PoiIds" class="form-control bg-light border-0" required />
                </div>
                <div class="col-12 mb-3">
                    <label asp-for="Description" class="form-label text-muted fw-bold">Mô tả Tour</label>
                    <textarea asp-for="Description" class="form-control bg-light border-0" rows="3" required></textarea>
                </div>
                <div class="col-12 mb-4">
                    <label class="form-label text-muted fw-bold">Cập nhật Hình Cover (Bỏ trống nếu giữ ảnh cũ)</label>
                    <input type="file" name="ImageFile" class="form-control bg-light border-0" accept="image/*" />
                </div>
            </div>
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-warning px-4 fw-bold shadow-sm" style="border-radius: 8px;">
                    <i class="bi bi-save me-1"></i> Lưu Thay Đổi
                </button>
            </div>
        </form>
    </div>
</div>