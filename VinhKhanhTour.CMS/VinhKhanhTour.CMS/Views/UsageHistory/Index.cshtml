@model IEnumerable<VinhKhanhTour.CMS.Models.UsageHistory>
@{
    ViewData["Title"] = "System History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark"><i class="bi bi-clock-history text-danger me-2"></i> Lịch Sử Hoạt Động (App)</h3>
</div>

<div class="card shadow-sm border-0 mb-4" style="border-radius: 10px;">
    <div class="card-body p-3">
        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">
            <label class="fw-bold text-muted mb-0">Lọc theo hành động:</label>
            <select name="actionType" class="form-select bg-light border-0 w-auto">
                <option value="">Tất cả hành động</option>
                @if (ViewBag.ActionTypes != null)
                {
                    foreach (var type in ViewBag.ActionTypes)
                    {
                        <option value="@type" selected="@(ViewBag.CurrentFilter == type ? "selected" : null)">@type</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-secondary shadow-sm" style="border-radius: 8px;">
                <i class="bi bi-filter"></i> Lọc
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter))
            {
                <a asp-action="Index" class="btn btn-light text-muted ms-2" title="Xóa bộ lọc">Xóa lọc</a>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="border-0">Thời Gian</th>
                        <th class="border-0">Thiết Bị & IP mạng</th>
                        <th class="border-0">Hành Động</th>
                        <th class="border-0">Chi Tiết</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu lịch sử.</td></tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            
                            <td class="fw-bold text-dark">
                                <div><i class="bi bi-phone text-primary me-1"></i> @(string.IsNullOrEmpty(item.DeviceId) ? "Unknown Device" : item.DeviceId)</div>
                                <small class="text-muted"><i class="bi bi-globe me-1"></i> IP: @(string.IsNullOrEmpty(item.IpAddress) ? "N/A" : item.IpAddress)</small>
                            </td>
                            
                            <td>
                                @if (item.ActionType == "Login" || item.ActionType == "Mở App")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success">@item.ActionType</span>
                                }
                                else if (item.ActionType == "Delete" || item.ActionType == "Thoát App")
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">@item.ActionType</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary">@item.ActionType</span>
                                }
                            </td>
                            <td class="text-muted text-break" style="max-width: 300px;">@item.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>