@model VinhKhanhTour.CMS.Models.Translation
@{
    ViewData["Title"] = "Translation Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
        <a asp-action="Index" class="btn btn-light text-muted me-3 shadow-sm" style="border-radius: 8px;"><i class="bi bi-arrow-left"></i> Back</a>
        <h3 class="fw-bold text-dark mb-0">Chi Tiết Bản Dịch</h3>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold shadow-sm" style="border-radius: 8px;"><i class="bi bi-pencil-square"></i> Chỉnh sửa</a>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <h5 class="fw-bold text-primary mb-3">Key: @Model.KeyName</h5>
        <p class="mb-2"><span class="fw-bold text-muted">Ngôn ngữ:</span> <span class="badge bg-success bg-opacity-10 text-success border border-success">@Model.LanguageCode</span></p>
        <p class="fw-bold text-muted mb-1">Nội dung dịch:</p>
        <div class="bg-light p-3 rounded text-dark text-break">
            @Model.TranslatedValue
        </div>
    </div>
</div>