@model IEnumerable<VinhKhanhTour.CMS.Models.Translation>
@{
    ViewData["Title"] = "Quản lý Bản Dịch POI";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark"><i class="bi bi-translate text-success me-2"></i> Bản Dịch Quán Ăn</h3>
    <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm" style="border-radius: 8px;">
        <i class="bi bi-plus-lg me-1"></i> Thêm Bản Dịch Mới
    </a>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="border-0">Ngôn Ngữ</th>
                        <th class="border-0">Quán Ăn Gốc (POI)</th>
                        <th class="border-0">Tên Đã Dịch</th>
                        <th class="border-0 text-end">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu.</td></tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-success bg-opacity-10 text-success border border-success">@item.LanguageCode</span></td>
                            <td class="fw-bold text-dark">@(item.Poi != null ? item.Poi.Name : "N/A")</td>
                            <td class="text-muted text-break">@item.Name</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-info shadow-sm me-1"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-warning shadow-sm me-1"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger shadow-sm"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>