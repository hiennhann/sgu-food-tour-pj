@model IEnumerable<VinhKhanhTour.CMS.Models.DeviceSubscription>

@{
    ViewData["Title"] = "Quản lý Cấp Quyền Thiết Bị";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-phone-vibrate text-primary"></i> Quản lý Phiên Người Dùng</h2>
</div>

<!-- Lưới hiển thị thông báo thành công sau khi nhấn nút Kích Hoạt -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3">Mã Máy (DeviceId)</th>
                        <th>Ngày Mở App</th>
                        <th>Thời Hạn (Trạng thái)</th>
                        <th>Ghi chú</th>
                        <th class="text-end px-4">Duyệt Thanh Toán</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var isTrial = !item.IsPaid && (DateTime.UtcNow - item.FirstLaunchDate).TotalHours < 24;
                        var isExpired = !item.IsPaid && (DateTime.UtcNow - item.FirstLaunchDate).TotalHours >= 24;

                        <tr>
                            <td class="px-4 fw-bold text-dark">
                                <span class="bg-light p-2 rounded text-monospace border">@item.DeviceId</span>
                            </td>
                            <td>@item.FirstLaunchDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.IsPaid)
                                {
                                    <span class="badge bg-success p-2"><i class="bi bi-unlock-fill"></i> Mở Khóa VIP</span>
                                }
                                else if (isTrial)
                                {
                                    <span class="badge bg-info text-dark p-2"><i class="bi bi-hourglass-split"></i> Đang Dùng Thử 24h</span>
                                }
                                else if (isExpired)
                                {
                                    <span class="badge bg-danger p-2"><i class="bi bi-lock-fill"></i> Đã Bị Khóa App</span>
                                }
                            </td>
                            <td class="text-muted small">@item.PaymentReceipt</td>
                            <td class="text-end px-4">
                                @if (!item.IsPaid)
                                {
                                    <form asp-action="Approve" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-success fw-bold shadow-sm">
                                            <i class="bi bi-check-circle"></i> KÍCH HOẠT VIP
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Revoke" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold" onclick="return confirm('Khách này đang dùng VIP. Chắc chắn muốn khóa lại?');">
                                            <i class="bi bi-x-circle"></i> Khóa Lại
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Any())
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-phone fs-1 text-secondary opacity-50"></i>
                <p class="mt-3 fs-5">Chưa có người dùng nào cài đặt và tải ứng dụng.</p>
            </div>
        }
    </div>
</div>