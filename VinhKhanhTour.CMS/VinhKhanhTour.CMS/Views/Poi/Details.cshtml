@model VinhKhanhTour.CMS.Models.Poi

@{
    ViewData["Title"] = "Chi tiết POI";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
        <a asp-action="Index" class="btn btn-light text-muted me-3 shadow-sm" style="border-radius: 8px;">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h3 class="fw-bold text-dark mb-0">Chi tiết: @Model.Name</h3>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold shadow-sm" style="border-radius: 8px;">
        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
    </a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0" style="border-radius: 10px;">
            <div class="card-body text-center p-4">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="~/images/@Model.ImageUrl" class="rounded-circle border shadow-sm mb-3" style="width: 150px; height: 150px; object-fit: cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 150px; height: 150px;">
                        <i class="bi bi-shop text-muted" style="font-size: 3rem;"></i>
                    </div>
                }
                <h4 class="fw-bold">@Model.Name</h4>
                <p class="text-muted">ID Hệ thống: #@Model.Id</p>
                
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Đang hoạt động</span>
                }
                else
                {
                    <span class="badge bg-secondary">Tạm ẩn</span>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card shadow-sm border-0 h-100" style="border-radius: 10px;">
            <div class="card-body p-4">
                <h5 class="fw-bold border-bottom pb-2 mb-3">Thông tin chi tiết</h5>
                <div class="row mb-3">
                    <div class="col-sm-3 text-muted fw-bold">Tọa độ:</div>
                    <div class="col-sm-9">@Model.Latitude, @Model.Longitude</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3 text-muted fw-bold">Kịch bản Audio:</div>
                    <div class="col-sm-9 p-3 bg-light rounded text-dark fst-italic">
                        "@(string.IsNullOrEmpty(Model.DisplayTtsScript) ? "Chưa có kịch bản âm thanh" : Model.DisplayTtsScript)"
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>