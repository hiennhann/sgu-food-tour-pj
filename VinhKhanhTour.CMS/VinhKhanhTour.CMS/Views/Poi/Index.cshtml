@model IEnumerable<VinhKhanhTour.CMS.Models.Poi>

@{
    ViewData["Title"] = "POI Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark"><i class="bi bi-geo-alt text-primary me-2"></i> POI Management</h3>
    <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm" style="border-radius: 8px;">
        <i class="bi bi-plus-lg me-1"></i> Add New POI
    </a>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="border-0">ID</th>
                        <th class="border-0">Tên Quán</th>
                        <th class="border-0">Hình Ảnh</th>
                        <th class="border-0">Tọa Độ (Lat, Lng)</th>
                        <th class="border-0 text-end">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu. Hãy thêm quán mới!</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted fw-bold">#@item.Id</td>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td><span class="badge bg-light text-primary border">@item.ImageUrl</span></td>
                            <td class="text-muted">@item.Latitude, @item.Longitude</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-light text-warning shadow-sm me-1"><i class="bi bi-pencil-square"></i></button>
                                <button class="btn btn-sm btn-light text-danger shadow-sm"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>