@model VinhKhanhTour.CMS.Models.Poi

@{
    ViewData["Title"] = "Add New POI";
}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-light text-muted me-3 shadow-sm" style="border-radius: 8px;">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <h3 class="fw-bold text-dark mb-0">Thêm Quán Mới (Interactive Map)</h3>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="alert alert-danger" style="border-radius: 8px;"></div>
    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 10px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-info-circle me-2"></i>Thông tin cơ bản</h5>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label text-muted fw-bold small">Tên Quán <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control bg-light border-0" placeholder="Nhập tên quán..." required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="DisplayName" class="form-label text-muted fw-bold small">Tên Hiển Thị (Không bắt buộc)</label>
                        <input asp-for="DisplayName" class="form-control bg-light border-0" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label text-muted fw-bold small">Địa chỉ quán <span class="text-danger">*</span></label>
                        <input asp-for="Address" class="form-control bg-light border-0" placeholder="VD: 40 Vĩnh Khánh..." required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label text-muted fw-bold small">Phân loại quán (Danh mục)</label>
                        <select asp-for="Category" class="form-select bg-light border-0">
                            <option value="Quán Ốc">Quán Ốc</option>
                            <option value="Hải Sản">Hải Sản</option>
                            <option value="Đồ Nướng">Đồ Nướng</option>
                            <option value="Đồ Uống">Đồ Uống</option>
                            <option value="Nhà Hàng">Nhà Hàng</option>
                            <option value="Ăn Vặt">Ăn Vặt</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label asp-for="Latitude" class="form-label text-muted fw-bold small">Vĩ độ (Lat)</label>
                            <input asp-for="Latitude" id="latInput" class="form-control bg-light border-0 text-primary fw-bold" value="10.761622" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Longitude" class="form-label text-muted fw-bold small">Kinh độ (Lng)</label>
                            <input asp-for="Longitude" id="lngInput" class="form-control bg-light border-0 text-primary fw-bold" value="106.661172" />
                        </div>
                        <small class="text-muted mt-1">💡 Click vào bản đồ hoặc tự nhập số liệu để cập nhật tọa độ.</small>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label asp-for="Priority" class="form-label text-muted fw-bold small">Độ ưu tiên</label>
                            <input asp-for="Priority" type="number" class="form-control bg-light border-0" value="1" />
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted fw-bold small">Trạng thái</label>
                            <select asp-for="IsActive" class="form-select bg-light border-0">
                                <option value="true">🟢 Đang hoạt động</option>
                                <option value="false">🔴 Tạm ẩn</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold small">Hình Ảnh Đại Diện (Không bắt buộc)</label>
                        <input type="file" name="ImageFile" class="form-control bg-light border-0" accept="image/*" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="DisplayTtsScript" class="form-label text-muted fw-bold small">Kịch bản Thuyết minh (Không bắt buộc)</label>
                        <textarea asp-for="DisplayTtsScript" class="form-control bg-light border-0" rows="3" placeholder="Để trống nếu chưa có audio..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm" style="border-radius: 8px;">
                        <i class="bi bi-save me-1"></i> Lưu Quán Ăn
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 10px; overflow: hidden;">
                <div id="poiMap" style="height: 100%; min-height: 600px; width: 100%;"></div>
            </div>
        </div>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
    var defaultLat = 10.761622;
    var defaultLng = 106.661172;

    var latElement = document.getElementById('latInput');
    var lngElement = document.getElementById('lngInput');

    var map = L.map('poiMap').setView([defaultLat, defaultLng], 16);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap'
    }).addTo(map);

    var marker = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(map);

    map.on('click', function (e) {
    var lat = e.latlng.lat.toFixed(6);
    var lng = e.latlng.lng.toFixed(6);
    marker.setLatLng(e.latlng);
    updateInputs(lat, lng);
    });

    marker.on('dragend', function (e) {
    var position = marker.getLatLng();
    updateInputs(position.lat.toFixed(6), position.lng.toFixed(6));
    });

    function updateInputs(lat, lng) {
    latElement.value = lat;
    lngElement.value = lng;
    }

    function updateMapFromInput() {
    var newLat = parseFloat(latElement.value.replace(',', '.'));
    var newLng = parseFloat(lngElement.value.replace(',', '.'));

    if (!isNaN(newLat) && !isNaN(newLng)) {
    var newLatLng = new L.LatLng(newLat, newLng);
    marker.setLatLng(newLatLng);
    map.panTo(newLatLng);
    }
    }

    latElement.addEventListener('input', updateMapFromInput);
    lngElement.addEventListener('input', updateMapFromInput);
    });
</script>