@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="fw-bold mb-4">HỆ THỐNG QUẢN TRỊ</h2>

<style>
    .stat-card { background: #fff; border-radius: 10px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.04); display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 5px solid; margin-bottom: 20px; }
    .stat-card.green { border-bottom-color: #2ecc71; }
    .stat-card.blue { border-bottom-color: #3498db; }
    .stat-card.orange { border-bottom-color: #f39c12; }
    .stat-card.purple { border-bottom-color: #9b59b6; }
    .stat-card .icon-box { background: #f8f9fa; width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .green .icon-box { color: #2ecc71; background: #eafaf1; }
    .blue .icon-box { color: #3498db; background: #ebf5fb; }
    .orange .icon-box { color: #f39c12; background: #fef5e7; }
    .purple .icon-box { color: #9b59b6; background: #f5eef8; }
</style>

<div class="row">
    <div class="col-md-3">
        <div class="stat-card green shadow-sm">
            <div><p class="text-muted mb-1 fw-bold">Tổng số Tour</p><h2 class="fw-bold mb-0">@ViewBag.TotalTours</h2></div>
            <div class="icon-box"><i class="bi bi-map"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card blue shadow-sm">
            <div><p class="text-muted mb-1 fw-bold">Tổng Quán Ăn (POI)</p><h2 class="fw-bold mb-0">@ViewBag.TotalPois</h2></div>
            <div class="icon-box"><i class="bi bi-geo-alt"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card orange shadow-sm">
            <div><p class="text-muted mb-1 fw-bold">File Âm Thanh</p><h2 class="fw-bold mb-0">@ViewBag.TotalAudios</h2></div>
            <div class="icon-box"><i class="bi bi-headphones"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card purple shadow-sm">
            <div><p class="text-muted mb-1 fw-bold">Bản Dịch Đa Ngôn Ngữ</p><h2 class="fw-bold mb-0">@ViewBag.TotalTranslations</h2></div>
            <div class="icon-box"><i class="bi bi-translate"></i></div>
        </div>
    </div>
</div>

<div class="alert alert-info border-0 shadow-sm mt-3" style="border-radius: 10px;">
    <i class="bi bi-info-circle-fill me-2"></i> Chào mừng bạn quay trở lại. Dữ liệu trên hệ thống đang được đồng bộ theo thời gian thực.
</div>