@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-speedometer2 text-primary me-2"></i> Bảng Theo Dõi</h2>
</div>

<div class="row mb-4">
    <div class="col-md-12 col-lg-3 mb-3">
        <div class="card bg-success text-white shadow-sm h-100" style="border-radius: 12px; border: none;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="fw-bold mb-0">Đang Hoạt Động (Live)</h6>
                    <div class="spinner-grow spinner-grow-sm text-light" role="status"></div>
                </div>
                <h2 id="liveCount" class="display-5 fw-bold mb-0">0</h2>
                <small class="text-white-50">thiết bị đang sử dụng</small>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-3 mb-3">
        <div class="card bg-primary text-white shadow-sm h-100" style="border-radius: 12px; border: none;">
            <div class="card-body">
                <h6 class="fw-bold mb-2">Tổng lượt truy cập</h6>
                <h2 class="display-5 fw-bold mb-0">@ViewBag.TotalAccess</h2>
                <small class="text-white-50">lượt truy cập toàn hệ thống</small>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-3 mb-3">
        <div class="card bg-warning text-dark shadow-sm h-100" style="border-radius: 12px; border: none;">
            <div class="card-body">
                <h6 class="fw-bold mb-2">Tổng số Quán (POI)</h6>
                <h2 class="display-5 fw-bold mb-0">@ViewBag.TotalPois</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-3 mb-3">
        <div class="card bg-info text-white shadow-sm h-100" style="border-radius: 12px; border: none;">
            <div class="card-body">
                <h6 class="fw-bold mb-2">Từ khóa đa ngôn ngữ</h6>
                <h2 class="display-5 fw-bold mb-0">@ViewBag.TotalTranslations</h2>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-header bg-white fw-bold py-3 border-bottom-0">
        <i class="bi bi-broadcast text-success me-2"></i> Trạm giám sát thiết bị đang sử dụng
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID Thiết Bị</th>
                        <th>Địa chỉ IP</th>
                        <th>Thời gian kết nối</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="deviceTableBody">
                    <tr id="noDataRow">
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-phone text-muted fs-1 d-block mb-2"></i>
                            Hiện không có khách đang sử dụng
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
    .withUrl("/monitoringHub")
    .build();

    const tbody = document.getElementById("deviceTableBody");
    const liveCount = document.getElementById("liveCount");
    const noDataRow = document.getElementById("noDataRow");

    // 1. Lắng nghe: Khi có thiết bị MỚI kết nối
    connection.on("DeviceConnected", function (device, totalCount) {
    liveCount.innerText = totalCount;
    if (noDataRow) noDataRow.style.display = 'none';

    const row = document.createElement("tr");
    row.id = "row_" + device.deviceId;
    row.innerHTML = `
    <td class="fw-bold text-primary ps-4">${device.deviceId}</td>
    <td><span class="badge bg-light text-dark border">${device.ipAddress}</span></td>
    <td><i class="bi bi-clock text-muted me-1"></i> ${device.connectTime}</td>
    <td><span class="badge bg-success bg-opacity-75"><span class="spinner-grow spinner-grow-sm me-1" style="width: 0.5rem; height: 0.5rem;"></span>Live</span></td>
    `;
    row.style.backgroundColor = '#d1e7dd';
    tbody.insertBefore(row, tbody.firstChild);
        
    setTimeout(() => row.style.backgroundColor = '', 1500);
    });

    // 2. Lắng nghe: Khi có thiết bị NGẮT kết nối
    connection.on("DeviceDisconnected", function (deviceId, totalCount) {
    liveCount.innerText = totalCount;
    const row = document.getElementById("row_" + deviceId);
    if (row) row.remove();
        
    if (totalCount === 0 && noDataRow) noDataRow.style.display = '';
    });

    // 3. THÊM MỚI: Lắng nghe danh sách thiết bị khi Admin vừa mở trang hoặc F5
    connection.on("LoadInitialDevices", function (devices, totalCount) {
    liveCount.innerText = totalCount;
        
    if (totalCount > 0 && noDataRow) {
    noDataRow.style.display = 'none';
    }

    // Xóa các dòng cũ (nếu có) để chuẩn bị vẽ lại từ đầu
    const existingRows = tbody.querySelectorAll("tr:not(#noDataRow)");
    existingRows.forEach(r => r.remove());

    // Vẽ lại toàn bộ thiết bị đang có sẵn trong RAM của Server
    devices.forEach(device => {
    const row = document.createElement("tr");
    row.id = "row_" + device.deviceId;
    row.innerHTML = `
    <td class="fw-bold text-primary ps-4">${device.deviceId}</td>
    <td><span class="badge bg-light text-dark border">${device.ipAddress}</span></td>
    <td><i class="bi bi-clock text-muted me-1"></i> ${device.connectTime}</td>
    <td><span class="badge bg-success bg-opacity-75"><span class="spinner-grow spinner-grow-sm me-1" style="width: 0.5rem; height: 0.5rem;"></span>Live</span></td>
    `;
    // Chèn vào cuối bảng thay vì đầu bảng
    tbody.appendChild(row);
    });
    });

    // Khởi động kết nối
    connection.start().catch(err => console.error("Lỗi SignalR: ", err));
</script>