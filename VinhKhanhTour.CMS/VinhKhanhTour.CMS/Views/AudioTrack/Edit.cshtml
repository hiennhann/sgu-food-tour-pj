@model VinhKhanhTour.CMS.Models.AudioTrack
@{
    ViewData["Title"] = "Edit Audio";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-light text-muted me-3 shadow-sm" style="border-radius: 8px;"><i class="bi bi-arrow-left"></i> Back</a>
    <h3 class="fw-bold text-dark mb-0">Cập nhật Audio Track</h3>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="PoiId" class="form-label text-muted fw-bold">Chọn Quán Ăn</label>
                    <select asp-for="PoiId" class="form-select bg-light border-0"
                            asp-items="@(ViewBag.PoiList as SelectList)" required>
                    </select>
                    <span asp-validation-for="PoiId" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LanguageCode" class="form-label text-muted fw-bold">Mã Ngôn Ngữ (Audio)</label>
                    <select asp-for="LanguageCode" class="form-select bg-light border-0" required>
                        <option value="">-- Chọn ngôn ngữ --</option>
                        <option value="vi-VN">Tiếng Việt (vi-VN)</option>
                        <option value="en-US">English - Mỹ (en-US)</option>
                        <option value="zh-CN">Chinese - Trung Quốc (zh-CN)</option>
                        <option value="ja-JP">Japanese - Nhật Bản (ja-JP)</option>
                        <option value="ko-KR">Korean - Hàn Quốc (ko-KR)</option>
                        <option value="fr-FR">French - Pháp (fr-FR)</option>
                        <option value="es-ES">Spanish - Tây Ban Nha (es-ES)</option>
                        <option value="de-DE">German - Đức (de-DE)</option>
                        <option value="ru-RU">Russian - Nga (ru-RU)</option>
                        <option value="it-IT">Italian - Ý (it-IT)</option>
                        <option value="pt-PT">Portuguese - Bồ Đào Nha (pt-PT)</option>
                        <option value="hi-IN">Hindi - Ấn Độ (hi-IN)</option>
                    </select>
                    <span asp-validation-for="LanguageCode" class="text-danger small"></span>
                </div>
                <div class="col-12 mb-4">
                    <label asp-for="AudioUrl" class="form-label text-muted fw-bold">Link File Audio (.mp3)</label>
                    <input asp-for="AudioUrl" class="form-control bg-light border-0" required />
                </div>
            </div>
            <hr class="text-muted my-4" />
            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-warning px-4 fw-bold shadow-sm text-dark" style="border-radius: 8px;">
                    <i class="bi bi-save me-1"></i> Lưu Thay Đổi
                </button>
            </div>
        </form>
    </div>
</div>