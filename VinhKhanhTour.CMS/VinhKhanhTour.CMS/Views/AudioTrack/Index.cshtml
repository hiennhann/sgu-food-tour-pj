@model IEnumerable<VinhKhanhTour.CMS.Models.AudioTrack>
@{
    ViewData["Title"] = "Audio Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark"><i class="bi bi-headphones text-info me-2"></i> Audio Management</h3>
    <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm" style="border-radius: 8px;">
        <i class="bi bi-plus-lg me-1"></i> Add Audio
    </a>
</div>

<div class="card shadow-sm border-0" style="border-radius: 10px;">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="border-0">ID Quán (PoiId)</th>
                        <th class="border-0">Ngôn Ngữ</th>
                        <th class="border-0">Link File Audio</th>
                        <th class="border-0 text-end">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu.</td></tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-danger">POI #@item.PoiId</td>
                            <td>
                                <span class="badge bg-info bg-opacity-10 text-info border border-info">@item.LanguageCode</span>
                            </td>
                            <td>
                                <a href="@item.AudioUrl" target="_blank" class="text-decoration-none">@item.AudioUrl</a>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-info shadow-sm me-1" title="Chi tiết/Nghe thử">
                                    <i class="bi bi-eye"></i>
                                </a>
                                
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-warning shadow-sm me-1" title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger shadow-sm" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>